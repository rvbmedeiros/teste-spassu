# =============================================================================
# .env  —  All-in-one Docker Compose (docker-compose.yml)
#
# Copy/rename este arquivo para .env na raiz do projeto e suba tudo com:
#   docker compose up -d
# =============================================================================

# ── Vault ──────────────────────────────────────────────────────────────────────
VAULT_TOKEN=spassu-dev-token

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=spassu
POSTGRES_USER=spassu
POSTGRES_PASSWORD=spassu

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_USER=spassu
RABBITMQ_PASSWORD=spassu

# ── Keycloak ───────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# JWK Set URI que os serviços Spring usam para validar tokens (acessível dentro
# do Docker via nome do serviço; o browser usa localhost:8080 diretamente).
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/master/protocol/openid-connect/certs

# ── CORS / origens permitidas ──────────────────────────────────────────────────
BFF_ORIGIN=http://localhost:8083
FRONTEND_ORIGIN=http://localhost:3000

# ── Frontend (compilado na imagem Docker) ──────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8083
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=spassu-frontend
