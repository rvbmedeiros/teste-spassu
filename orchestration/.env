# =============================================================================
# orchestration/.env  —  Dev local (Spring Boot rodando fora do Docker)
# =============================================================================
# Secrets de RabbitMQ e URL do microservice são lidos do Vault.
# Basta apontar para o Vault local (docker-compose.infra.yml).
# =============================================================================

VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_TOKEN=spassu-dev-token
