# =============================================================================
# microservice/.env  —  Dev local (Spring Boot rodando fora do Docker)
# =============================================================================
# Secrets de banco e RabbitMQ são lidos do Vault automaticamente.
# Basta apontar para o Vault local (docker-compose.infra.yml).
# =============================================================================

VAULT_HOST=localhost
VAULT_PORT=8200
VAULT_TOKEN=spassu-dev-token
