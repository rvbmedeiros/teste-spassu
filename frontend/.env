# =============================================================================
# frontend/.env  —  Dev local (Vite dev server)
# =============================================================================
# Vite só expõe variáveis com prefixo VITE_ ao código do browser.
# =============================================================================

# URL base do BFF (Gateway)
VITE_API_BASE_URL=http://localhost:8083

# Keycloak
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=spassu-frontend
